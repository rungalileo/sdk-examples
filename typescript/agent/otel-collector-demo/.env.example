# === Galileo Configuration ===
GALILEO_CONSOLE_URL=https://app.galileo.ai
GALILEO_API_KEY=your-galileo-api-key
GALILEO_PROJECT=otel-ts-collector-demo
GALILEO_LOG_STREAM=dev

# === OpenAI (only needed when USE_REAL_LLM=true) ===
OPENAI_API_KEY=your-openai-api-key

# === Mode ===
# Set to "true" to make real OpenAI API calls; default is simulated
USE_REAL_LLM=false

# === OTEL (optional overrides) ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
